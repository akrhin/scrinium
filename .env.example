# Scrinium — RAG Chat over your documents
# Copy to .env and fill in your values
# .env is in .gitignore — secrets stay local

# Auth
ADMIN_USER=admin
ADMIN_PASSWORD=change_me

# LLM (OpenAI-compatible API)
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Embedding provider — local (fastembed, ~700MB RAM) or remote (API, 0 RAM)
# local:  jina-embeddings-v3 (бесплатно, CPU, ~700 MB)
# remote: OpenAI-совместимый API (нужен ключ, 0 RAM на сервере)
EMBEDDING_PROVIDER=local

# Для remote-режима (EMBEDDING_PROVIDER=remote):
# EMBEDDING_API_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_API_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536  # для text-embedding-3-small; для jina — 1024

# Docling provider — local (subprocess, ~2GB RAM при конверте) or remote (HTTP API, 0 RAM)
# local:  запускает docling-конвертер в подпроцессе (память освобождается после)
# remote: отправляет файл на внешний API (нужен docling-serve или аналогичный)
DOCLING_PROVIDER=local

# Для remote-режима (DOCLING_PROVIDER=remote):
# DOCLING_API_URL=http://192.168.1.x:8080
# DOCLING_API_KEY=

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=

# ChromaDB — shared with docling-search MCP
# Default: ~/docling-search/chroma/
# CHROMA_DIR=/home/sintez/docling-search/chroma

# Storage
DB_PATH=./data/scrinium.db
UPLOAD_DIR=./data/uploads
